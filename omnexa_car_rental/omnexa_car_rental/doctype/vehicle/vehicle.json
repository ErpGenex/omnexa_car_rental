			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "status",
			"fieldtype": "Select",
			"label": "Status",
			"options": "Available\nRented\nMaintenance\nOut of Service",
			"default": "Available",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "control_section",
			"fieldtype": "Section Break",
			"label": "Control"
		},
		{
			"fieldname": "asset_owner",
			"fieldtype": "Link",
			"label": "Asset Owner",
			"options": "User"
		}
