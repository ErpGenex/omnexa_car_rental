{
	"actions": [],
	"doctype": "DocType",
	"engine": "InnoDB",
	"module": "Omnexa Car Rental",
	"name": "Rental CRM Campaign",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"export": 1,
			"print": 1,
			"email": 1,
			"share": 1,
			"report": 1
		},
		{
			"role": "Fleet Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"export": 1,
			"print": 1,
			"email": 1,
			"share": 0,
			"report": 1
		},
		{
			"role": "Rental Agent",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"export": 0,
			"print": 1,
			"email": 0,
			"share": 0,
			"report": 1
		}
	],
	"sort_field": "modified",
	"sort_order": "DESC",
	"track_changes": 1,
	"autoname": "format:CRM-{YYYY}-{#####}",
	"fields": [
		{
			"fieldname": "campaign_name",
			"fieldtype": "Data",
			"label": "Campaign Name",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "company",
			"fieldtype": "Link",
			"label": "Company",
			"options": "Company",
			"reqd": 1
		},
		{
			"fieldname": "branch",
			"fieldtype": "Link",
			"label": "Branch",
			"options": "Branch",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "segment",
			"fieldtype": "Select",
			"label": "Segment",
			"options": "All\nCorporate\nRetail\nLoyalty\nAt-Risk"
		},
		{
			"fieldname": "channel",
			"fieldtype": "Select",
			"label": "Channel",
			"options": "Email\nSMS\nWhatsApp\nPush"
		},
		{
			"default": "Draft",
			"fieldname": "status",
			"fieldtype": "Select",
			"label": "Status",
			"options": "Draft\nScheduled\nSent\nCancelled"
		}
	]
}
