			"create": 1,
			"delete": 1,
			"print": 1,
			"email": 1,
			"export": 1,
			"report": 1,
			"share": 1
		},
		{
			"role": "Rental Agent",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"print": 1,
			"email": 1,
			"export": 1,
			"report": 1,
			"share": 1
		},
		{
			"role": "Accountant",
