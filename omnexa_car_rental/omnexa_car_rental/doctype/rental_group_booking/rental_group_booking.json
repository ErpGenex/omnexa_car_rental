			"in_list_view": 1
		},
		{
			"fieldname": "corporate_account",
			"fieldtype": "Link",
			"label": "Corporate Account",
			"options": "Rental Corporate Account",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "vehicle_count",
			"fieldtype": "Int",
			"label": "Vehicles",
			"reqd": 1
		},
		{
			"fieldname": "start_datetime",
			"fieldtype": "Datetime",
			"label": "Start",
			"reqd": 1
		},
		{
			"fieldname": "end_datetime",
			"fieldtype": "Datetime",
			"label": "End",
			"reqd": 1
		},
		{
			"default": "Draft",
			"fieldname": "status",
			"fieldtype": "Select",
			"label": "Status",
			"options": "Draft\nConfirmed\nCancelled",
			"in_list_view": 1
		}
	]
