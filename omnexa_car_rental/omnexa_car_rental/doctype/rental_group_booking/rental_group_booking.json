	"engine": "InnoDB",
	"module": "Omnexa Car Rental",
	"name": "Rental Group Booking",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"export": 1,
			"print": 1,
			"email": 1,
			"share": 1,
			"report": 1
		},
		{
			"role": "Fleet Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"export": 1,
			"print": 1,
			"email": 1,
			"share": 0,
			"report": 1
		},
		{
			"role": "Rental Agent",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"export": 0,
			"print": 1,
			"email": 0,
			"share": 0,
			"report": 1
		}
	],
	"sort_field": "modified",
	"sort_order": "DESC",
