  {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1, "in_list_view": 1},
  {"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1, "in_list_view": 1},
  {"fieldname": "rental_type", "fieldtype": "Select", "label": "Rental Type", "options": "Hourly\nDaily\nWeekly\nMonthly\nLong-term lease", "reqd": 1},
  {"fieldname": "rental_mode", "fieldtype": "Select", "label": "Rental Mode", "options": "Self Drive\nWith Driver", "reqd": 1},
  {"fieldname": "start_datetime", "fieldtype": "Datetime", "label": "Start Date-Time", "reqd": 1},
  {"fieldname": "end_datetime", "fieldtype": "Datetime", "label": "End Date-Time", "reqd": 1},
  {"fieldname": "booking_status", "fieldtype": "Select", "label": "Booking Status", "options": "Inquiry\nConfirmed\nCancelled\nConverted", "default": "Inquiry", "reqd": 1, "in_list_view": 1},
  {"fieldname": "currency", "fieldtype": "Link", "label": "Currency", "options": "Currency"},
  {"fieldname": "estimated_amount", "fieldtype": "Currency", "label": "Estimated Amount", "default": "0"}
 ],
