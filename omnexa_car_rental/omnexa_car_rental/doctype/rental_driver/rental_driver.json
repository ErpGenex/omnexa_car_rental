			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "branch",
			"fieldtype": "Link",
			"label": "Branch",
			"options": "Branch",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "license_number",
			"fieldtype": "Data",
			"label": "License Number",
			"reqd": 1
		},
		{
