			"in_list_view": 1
		},
		{
			"fieldname": "position",
			"fieldtype": "Data",
			"label": "Position"
		},
		{
			"fieldname": "installed_on",
			"fieldtype": "Date",
			"label": "Installed On"
		},
		{
			"fieldname": "tread_depth_mm",
			"fieldtype": "Float",
			"label": "Tread Depth (mm)"
		},
		{
			"default": "In Service",
