{
 "actions": [],
 "allow_rename": 1,
 "autoname": "format:VMR-{YYYY}-{#####}",
 "doctype": "DocType",
 "engine": "InnoDB",
 "field_order": [
  "identity_section",
  "vehicle",
  "company",
  "branch",
  "maintenance_type",
  "posting_date",
  "odometer_km",
  "cost_amount",
  "status",
  "notes",
  "control_section",
  "service_provider"
 ],
 "fields": [
  {
   "fieldname": "identity_section",
   "fieldtype": "Section Break",
   "label": "Maintenance Record Identity"
  },
  {
   "fieldname": "vehicle",
   "fieldtype": "Link",
   "label": "Vehicle",
   "options": "Vehicle",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "company",
   "fieldtype": "Link",
   "label": "Company",
   "options": "Company",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "branch",
   "fieldtype": "Link",
   "label": "Branch",
   "options": "Branch",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "maintenance_type",
   "fieldtype": "Select",
   "label": "Maintenance Type",
   "options": "Preventive\nCorrective\nOil Change\nTire Replacement",
   "reqd": 1
  },
  {
   "fieldname": "posting_date",
   "fieldtype": "Date",
   "label": "Posting Date",
   "reqd": 1
  },
  {
   "fieldname": "odometer_km",
   "fieldtype": "Float",
   "label": "Odometer (KM)",
   "default": "0"
  },
  {
   "fieldname": "cost_amount",
   "fieldtype": "Currency",
   "label": "Cost Amount",
   "default": "0"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Open\nCompleted\nCancelled",
   "default": "Open",
   "in_list_view": 1
  },
  {
   "fieldname": "notes",
   "fieldtype": "Small Text",
   "label": "Notes"
  },
  {
   "fieldname": "control_section",
   "fieldtype": "Section Break",
   "label": "Control"
  },
  {
   "fieldname": "service_provider",
   "fieldtype": "Data",
   "label": "Service Provider"
  }
 ],
 "module": "Omnexa Car Rental",
 "name": "Vehicle Maintenance Record",
